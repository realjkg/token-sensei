{
  # LAN deployment — use Caddy's built-in CA instead of ACME/Let's Encrypt.
  # Run "make caddy-trust" to export the root cert and install it on tablets.
  local_certs
  admin off
}

# HTTPS: TLS-terminate and proxy to nginx
:443 {
  tls internal

  reverse_proxy ui:80 {
    header_up Host              {host}
    header_up X-Real-IP         {remote_host}
    header_up X-Forwarded-For   {remote_host}
    header_up X-Forwarded-Proto https
  }
}

# HTTP → HTTPS redirect (tablets and browsers follow automatically)
:80 {
  redir https://{host}{uri} permanent
}
