# Ratio environment configuration. EVERY variable below is optional: with none
# set, the app runs fully offline on the data-grounded mock (MockAIClient).

# --- Wave3b AIClient seam (server-side only — keys NEVER reach the browser) ---
# Provider router. One of: claude | openai | openllm | mock. Default: mock.
AI_PROVIDER=mock

# Claude (AI_PROVIDER=claude). Model is optional (defaults to claude-sonnet-4).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# OpenAI (AI_PROVIDER=openai). Model is optional (defaults to gpt-4o).
OPENAI_API_KEY=
OPENAI_MODEL=

# OpenLLM — any OpenAI-compatible endpoint (Ollama, vLLM, LM Studio).
# Base URL + model are required when AI_PROVIDER=openllm; key is optional.
OPENLLM_BASE_URL=
OPENLLM_MODEL=
OPENLLM_API_KEY=

# Client routing flag (NOT a credential): mock | live. `live` proxies the
# browser through /api/v1/ai/chat to the server-side provider above. Default: mock.
NEXT_PUBLIC_AI_MODE=mock

# --- Wave3b API gateway (server-side only) ---
# Bearer token for the /api/v1/ai/chat gateway (one key per tenant). When unset
# AND AI_PROVIDER=mock (the default), auth is NOT enforced so the offline demo
# and CI stay green with zero config. Enforcement turns on when this is set OR a
# live provider (claude|openai|openllm) is selected; requests then need
# `Authorization: Bearer <token>`. Standard tier: 1,000 req/min per tenant.
RATIO_API_TOKEN=

# --- Phase 1 legacy (AgentClient) ---
# Legacy: NEXT_PUBLIC_ANTHROPIC_API_KEY — the Phase 1 client-side agent key.
# Superseded by the server-proxied AIClient seam above; safe to leave unset.
NEXT_PUBLIC_ANTHROPIC_API_KEY=

